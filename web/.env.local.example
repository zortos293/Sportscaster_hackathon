# Copy to .env.local and fill in values. All keys are optional for the basic demo.
# Restart `npm run dev` after changes.

# --- Voice (required for AI TTS on hobby horsing / imported matches; not used on ESPN highlight demos) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_flash_v2_5

# --- AI commentary (template fallback works without these) ---
CURSOR_API_KEY=
CURSOR_COMMENTARY_MODEL=composer-2.5

# Optional — fire-and-forget automation webhook (see automations/sportscaster-commentary.md)
# CURSOR_AUTOMATION_WEBHOOK_URL=
# CURSOR_AUTOMATION_TOKEN=

# OpenAI fallback if Cursor is unavailable
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Admin / imports ---
# Expose /admin in production (on by default in local dev)
# ADMIN_ENABLED=true

# Apify actors for Flashscore/FotMob event enrichment during full-match import
# APIFY_TOKEN=

# --- Convex (optional — auth + commentary cache; leave empty for demo mode) ---
# NEXT_PUBLIC_CONVEX_URL=
# CONVEX_SITE_URL=
# CACHE_WEBHOOK_SECRET=
# NEXT_PUBLIC_DISABLE_CONVEX_AUTH=true
